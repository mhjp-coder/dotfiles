{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
  ],
  "cpu": {
    "interval": 15,
    "format": "´Æ╝ {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "¯┐à  {}%",
    "max-length": 10
  },
  "custom/power": {
    "tooltip": false,
    "format": "´Çæ",
    "on-click": "$HOME/.config/rofi/powermenu/powermenu.sh"
  },
  "custom/launcher": {
    "tooltip": false,
    "format": "´îâ",
    "on-click": "$HOME/.config/rofi/launchers/launcher.sh"
  },
  "tray": {
    "tooltip": false,
    "icon-size": 24,
    "spacing": 10
  },
  "custom/music": {
      "format": "´Çü {}",
      "escape": true,
      "interval": 5,
      "tooltip": false,
      "exec": "playerctl metadata --format='{{ title }}'",
      "on-click": "playerctl play-pause",
      "max-length": 50
  },
  "clock": {
      "timezone": "America/Edmonton",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "´Çù {:%d/%m/%Y L%I:%M %p}",
      "format": "´Çù {:L%I:%M %p  %b,%e}"
  },
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon} {volume}%",
    "scroll-step": 2,
    "format-muted": "¾░Øƒ",
    "on-click": "volumectl toggle",
    "format-icons": {
      "default": [
        "´Çª",
        "´Çº",
        "´Ç¿"
      ]
    }
  },
  "network": {
    "tooltip": false,
    "format-wifi": "¾░û® {essid} ({signalStrength}%)",
    "format-ethernet": "¾░▒ô {ipaddr}/{cidr}",
    "format-disconnected": "¾░àø Disconnected"
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "<span font_scale='subscript' size='x-small'>{name}</span> {icon}",
    "format-icons": {
      "1": "¯Øà",
      "2": "¾░¿×",
      "3": "¾░ØÜ",
      "4": "´äá",
      "5": "¾░Ö»",
      "6": "¯£Å",
      "7": "¾░ëô",
      "8": "´îé",
      "9": "¾░Åå",
      "10": "´îâ"
    },
    "persistent-workspaces": {
      "DP-4": [
        1,
        3,
        5,
        7,
        9
      ],
      "DP-5": [
        2,
        4,
        6,
        8,
        10
      ]
    }
  },
  "custom/updates": {
    "tooltip": false,
    "format": "¾░úç {} Update(s)",
    "exec": "checkupdates | wc -l",
    "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "kitty -e paru && dunstify --appname='Arch Updates' 'The system has been updated'"
  }
}
