{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
  ],
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon}  {volume}%",
    "scroll-step": 5,
    "format-muted": "<span size='130%'>≤░ζθ</span>",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": [
        "<span size='130%'>ΎΑο</span>",
        "<span size='130%'>ΎΑπ</span>",
        "<span size='130%'>ΎΑρ</span>"
      ]
    }
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "<span font_scale='subscript' size='xx-small'>{name}</span>  {icon}",
    "format-icons": {
      "1": "<span size='130%'>ΌζΖ</span>",
      "2": "<span size='130%'>ΎΕι</span>",
      "3": "<span size='130%'>≤░ρη</span>",
      "4": "<span size='130%'>≤░ζγ</span>",
      "5": "<span size='130%'>≤░βψ</span>",
      "6": "<span size='130%'>ΌεΠ</span>",
      "7": "<span size='130%'>≤░ΚΥ</span>",
      "8": "<span size='130%'>ΎΝΓ</span>",
      "9": "<span size='130%'>≤░ΠΗ</span>",
      "10": "<span size='130%'>ΎΝΔ</span>",
      "default": "<span size='130%'>ΎΝΔ</span>"
    },
    "persistent_workspaces": {
      "1": [
        "DP-1"
      ],
      "2": [
        "DP-2"
      ],
      "3": [
        "DP-1"
      ],
      "4": [
        "DP-2"
      ],
      "5": [
        "DP-1"
      ],
      "6": [
        "DP-2"
      ],
      "7": [
        "DP-1"
      ],
      "8": [
        "DP-2"
      ],
      "9": [
        "DP-1"
      ],
      "10": [
        "DP-2"
      ]
    }
  },
  "network": {
    "format-wifi": "<span size='130%'>≤░Ψσ</span>  {essid} ({signalStrength}%)",
    "format-ethernet": "<span size='130%'>≤░▒Υ</span>  {ipaddr}/{cidr}",
    "format-disconnected": "<span size='130%'>≤░Ζδ</span>  Disconnected"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "simpleclock": {
    "interval": 60,
    "format": "{:<span size='130%'>ΎΑΩ</span>  %I:%M %p  %b,%e}"
  },
  "cpu": {
    "interval": 15,
    "format": "<span size='135%'>≤░╗ι</span>  {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "<span size='120%'>ΎΤ╝</span>  {}%",
    "max-length": 10
  },
  "custom/launcher": {
    "format": "ΎΝΔ ",
    "on-click": "wofi -i --show drun --allow-images --no-actions"
  },
  "custom/power": {
    "format": "<span size='120%'>ΎΑΣ</span>  ",
    "on-click": "wlogout"
  },
  "custom/updates": {
    "format": "<span size='130%'>≤░μΘ</span>  {} Update(s)",
    "exec": "checkupdates-with-aur | wc -l",
    "exec-if": "[[ $(checkupdates-with-aur | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "kitty -e yay && notify-send '************************* The system has been updated *************************' "
  }
}
