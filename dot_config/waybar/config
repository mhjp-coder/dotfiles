{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
