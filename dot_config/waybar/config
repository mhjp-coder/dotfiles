{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
  ],
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon}  {volume}%",
    "scroll-step": 5,
    "format-muted": "<span size='130%'>󰝟</span>",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": [
        "<span size='130%'></span>",
        "<span size='130%'></span>",
        "<span size='130%'></span>"
      ]
    }
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "<span font_scale='subscript' size='xx-small'>{name}</span>  {icon}",
    "format-icons": {
      "1": "<span size='130%'></span>",
      "2": "<span size='130%'></span>",
      "3": "<span size='130%'>󰨞</span>",
      "4": "<span size='130%'>󰝚</span>",
      "5": "<span size='130%'>󰙯</span>",
      "6": "<span size='130%'></span>",
      "7": "<span size='130%'>󰉓</span>",
      "8": "<span size='130%'></span>",
      "9": "<span size='130%'>󰏆</span>",
      "10": "<span size='130%'>󰨞</span>",
      "default": "<span size='130%'></span>"
    },
    "persistent_workspaces": {
      "1": [
        "DP-2"
      ],
      "2": [
        "DP-3"
      ],
      "3": [
        "DP-2"
      ],
      "4": [
        "DP-3"
      ],
      "5": [
        "DP-2"
      ],
      "6": [
        "DP-3"
      ],
      "7": [
        "DP-2"
      ],
      "8": [
        "DP-3"
      ],
      "9": [
        "DP-2"
      ],
      "0": [
        "DP-3"
      ]
    }
  },
  "network": {
    "format-wifi": "<span size='130%'>󰖩</span>  {essid} ({signalStrength}%)",
    "format-ethernet": "<span size='130%'>󰱓</span>  {ipaddr}/{cidr}",
    "format-disconnected": "<span size='130%'>󰅛</span>  Disconnected"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "clock": {
    "interval": 60,
    "format": "{:<span size='130%'></span>  %I:%M %p  %b,%e}"
  },
  "cpu": {
    "interval": 15,
    "format": "<span size='135%'>󰻠</span>  {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "<span size='120%'></span>  {}%",
    "max-length": 10
  },
  "custom/launcher": {
    "format": " ",
    "on-click": "wofi -i --show drun --allow-images --no-actions"
  },
  "custom/power": {
    "format": "<span size='120%'></span>  ",
    "on-click": "wlogout"
  },
  "custom/updates": {
    "format": "<span size='130%'>󰣇</span>  {} Update(s)",
    "exec": "checkupdates | wc -l",
    "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "alacritty -e yay && notify-send '************************* The system has been updated *************************' "
  }
}
