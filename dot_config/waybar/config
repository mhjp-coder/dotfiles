{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
  ],
  "cpu": {
    "interval": 15,
    "format": "<span>󰻠</span> {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "<span></span> {}%",
    "max-length": 10
  },
  "custom/power": {
    "tooltip": false,
    "format": "<span></span>",
    "on-click": "wlogout"
  },
  "custom/launcher": {
    "tooltip": false,
    "format": "",
    "on-click": "wofi -i --show drun --allow-images --no-actions"
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "<span font_scale='subscript' size='x-small'>{name}</span> {icon}",
    "format-icons": {
      "1": "<span></span>",
      "2": "<span>󰨞</span>",
      "3": "<span>󰝚</span>",
      "4": "<span></span>",
      "5": "<span>󰙯</span>",
      "6": "<span></span>",
      "7": "<span>󰉓</span>",
      "8": "<span></span>",
      "9": "<span>󰏆</span>",
      "10": "<span></span>"
    },
    "persistent-workspaces": {
      "DP-1": [
        1,
        3,
        5,
        7,
        9
      ],
      "DP-2": [
        2,
        4,
        6,
        8,
        10
      ]
    }
  },
  "custom/updates": {
    "tooltip": false,
    "format": "<span>󰣇</span> {} Update(s)",
    "exec": "checkupdates-with-aur | wc -l",
    "exec-if": "[[ $(checkupdates-with-aur | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "kitty -e yay && dunstify --appname='Arch Updates' 'The system has been updated'"
  },
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon} {volume}%",
    "scroll-step": 2,
    "format-muted": "<span>󰝟</span>",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": [
        "<span></span>",
        "<span></span>",
        "<span></span>"
      ]
    }
  },
  "network": {
    "tooltip": false,
    "format-wifi": "<span>󰖩</span> {essid} ({signalStrength}%)",
    "format-ethernet": "<span>󰱓</span> {ipaddr}/{cidr}",
    "format-disconnected": "<span>󰅛</span> Disconnected"
  },
  "clock": {
    "tooltip": false,
    "interval": 60,
    "format": "<span></span> {:L%I:%M %p  %b,%e}"
  },
  "tray": {
    "tooltip": false,
    "icon-size": 18,
    "spacing": 10
  }
}
