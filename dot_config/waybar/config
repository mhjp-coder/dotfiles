{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/power",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "tray"
  ],
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon} {volume}%",
    "scroll-step": 5,
    "format-muted": "󰝟",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    }
  },
  "hyprland/workspaces": {
    "all-outputs": false,
    "format": "{name}: {icon}",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "󰨞",
      "4": "",
      "5": "󰙯",
      "6": "",
      "active": "󰻿",
      "default": "󰼀"
    },
    "persistent_workspaces": {
      "1": [
        "DP-2"
      ],
      "2": [
        "DP-3"
      ],
      "3": [
        "DP-2"
      ],
      "4": [
        "DP-3"
      ],
      "5": [
        "DP-2"
      ],
      "6": [
        "DP-3"
      ]
    }
  },
  "network": {
    "format-wifi": "󰖩 {essid} ({signalStrength}%)",
    "format-ethernet": "󰱓 {ipaddr}/{cidr}",
    "format-disconnected": "󰅛 Disconnected"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "clock": {
    "interval": 60,
    "format": "{:  %I:%M %p  %b,%e}"
  },
  "cpu": {
    "interval": 15,
    "format": "󰻠 {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "  {}%",
    "max-length": 10
  },
  "custom/launcher": {
    "format": " ",
    "on-click": "wofi -i --show drun --allow-images --no-actions"
  },
  "custom/power": {
    "format": " ",
    "on-click": "wlogout"
  },
  "custom/updates": {
    "format": "󰣇 {} Update(s)",
    "exec": "checkupdates | wc -l",
    "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "alacritty -e yay && notify-send '******************************** The system has been updated ********************************' "
  }
}
