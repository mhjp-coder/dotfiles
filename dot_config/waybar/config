{
  "layer": "top",
  "modules-left": [
    "cpu",
    "memory",
    "custom/launcher"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "clock",
    "custom/power",
    "tray"
  ],
  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    }
  },
  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "1": "<span size='200%'></span>",
      "2": "<span size='135%'></span>",
      "3": "<span size='135%'>󰨞</span>",
      "4": "<span size='135%'></span>",
      "5": "<span size='135%'>󰙯</span>",
      "6": "<span size='135%'></span>",
      "active": "<span size='135%'>󰻿</span>",
      "default": "<span size='135%'>󰼀</span>"
    },
    "persistent_workspaces": {
      "DP-2": [
        1,
        2,
        3
      ],
      "DP-3": [
        4,
        5,
        6
      ]
    }
  },
  "network": {
    "format-wifi": "{essid} ({signalStrength}%) ",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
    "format-disconnected": "Disconnected ⚠"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "clock": {
    "format": "{:  %I:%M %p  %d/%m/%Y}"
  },
  "cpu": {
    "interval": 15,
    "format": " {}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": " {}%",
    "max-length": 10
  },
  "custom/launcher": {
    "format": " ",
    "on-click": "wofi -i --show drun --allow-images --no-actions"
  },
  "custom/power": {
    "format": " ",
    "on-click": "wlogout"
  },
  "custom/updates": {
    "format": "{} Update(s)",
    "exec": "checkupdates | wc -l",
    "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
    "interval": 300,
    "on-click": "alacritty -e yay && notify-send '******************************** The system has been updated ********************************' "
  }
}
