# See https://wiki.hyprland.org/Configuring/Monitors/

# machine-specific configuration
{{- if eq .machine_location "work" }}

# Work Desktop
monitor = DP-2, 3440x1440@60, 0x0, 1,
monitor = DP-1, 3440x1440@60, 0x-1440, 1,
workspace = 1,3,5,7,9, monitor:DP-1
workspace = 2,4,6,8,0, monitor:DP-2

{{ else if eq .machine_location "home" -}}

# Home Desktop
monitor = DP-1, 2560x1440@165, 0x0, 1
monitor = DP-2, 2560x1440@60, 2560x0, 1
workspace = r[1,3,5,7,9], monitor:DP-2
workspace = r[2,4,6,8,0], monitor:DP-1

{{ end -}}

monitor = ,preferred,auto,1
